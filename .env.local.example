# ---- Firebase cliente (publico, va al navegador) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Clave VAPID para notificaciones web push (opcional, FCM):
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ---- Firebase admin (servidor, SECRETO, solo en Vercel/local) ----
# De la cuenta de servicio (Project settings > Service accounts > Generate new key)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Pega la private_key completa entre comillas, con los \n tal cual:
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
